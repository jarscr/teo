{
    "name": "jarscr/teo",
    "type": "project",
    "description": "TEO Simple PHP Framework for building web applications in PHP",
    "keywords": ["mvc", "framework", "php", "costa rica", "web", "jarscr", "teo"],
    "homepage": "https://github.com/jarscr/teo",
    "license": "MIT",
    "version": "1.0.8",
    "authors": [
        {
            "name": "Alfredo Rodríguez",
            "email": "jarscr@gmail.com",
            "homepage": "https://www.jarscr.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "delight-im/auth": "^8.3",
        "mpdf/mpdf": "^8.2",
        "twig/twig": "^3.14",
        "symfony/translation": "^7.2",
        "symfony/twig-bridge": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "sentry/sentry": "^4.10"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "Core\\": "Core/",
            "App\\": "App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
